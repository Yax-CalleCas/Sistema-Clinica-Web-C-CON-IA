<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinPiura</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css">
    <link href="~/css/site-layout.css" rel="stylesheet">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar" aria-label="Menú principal">
            <a class="brand" asp-controller="@(User.Identity?.IsAuthenticated == true ? "Acceso" : "Home")" asp-action="@(User.Identity?.IsAuthenticated == true ? "RedireccionRol" : "Index")">
                <div class="brand-logo"><i class="las la-clinic-medical"></i></div>
                <div class="brand-text"><h4>ClinPiura</h4><span>Healthcare Platform</span></div>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="profile-card d-flex align-items-center gap-3">
                    <img src="" alt="Avatar de @User.Identity.Name" />
                    <div>
                        <div class="profile-name">@User.Identity.Name</div>
                        <div class="profile-role">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</div>
                    </div>
                </div>
            }

            <nav>
                <div class="sidebar-section-title">Navegación</div>
                <ul class="sidebar-menu">
                    @* Ejemplo de estructura limpia, aplicar a todos los roles *@
                    @if (User.IsInRole("Administrador"))
                    {
                        <li><a class="sidebar-link" asp-controller="Admin" asp-action="Dashboard"><i class="las la-chart-pie"></i> <span>Dashboard</span></a></li>
                        <li><a class="sidebar-link" asp-controller="Medicamentos" asp-action="Index"><i class="las la-capsules"></i> <span>Farmacia</span></a></li>
                    }
                </ul>
            </nav>

            <div class="sidebar-bottom">
                <button type="button" class="logout-btn" onclick="confirmarSalida()" aria-label="Cerrar sesión">
                    <i class="las la-sign-out-alt me-2"></i> Cerrar Sesión
                </button>
            </div>
        </aside>

        <div class="main-wrapper">
            <header class="topbar d-flex justify-content-between align-items-center gap-3">
                <button class="mobile-toggle" id="toggleSidebar" aria-label="Abrir menú">
                    <i class="las la-bars"></i>
                </button>
                <main class="content-area">@RenderBody()</main>
            </header>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    <script>
        document.getElementById('toggleSidebar')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('show');
        });

        async function confirmarSalida() {
            const { isConfirmed } = await Swal.fire({
                title: '¿Cerrar sesión?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#14B8A6',
                confirmButtonText: 'Sí, salir'
            });
            if (isConfirmed) window.location.href = '@Url.Action("Salir", "Home")';
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>