            </button>

            <div class="collapse navbar-collapse" id="menu">

                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
                    <li class="nav-item"><a class="nav-link" href="#">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="#clinicas">Clínicas</a></li>
                    <li class="nav-item"><a class="nav-link" href="#especialidades">Especialidades</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contacto">Contacto</a></li>
                </ul>

            </div>

        </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="container">

            <div class="row align-items-center">

                <div class="col-lg-8">

                    <span class="badge bg-primary px-4 py-2 rounded-pill fs-6 mb-4">
                        Directorio Médico Premium
                    </span>

                    <h1>
                        Encuentra las mejores clínicas en Trujillo
                    </h1>

                    <p class="mt-4">
                        Descubre centros médicos, especialistas y servicios de salud con atención moderna, opiniones verificadas y tecnología de primer nivel.
                    </p>

                    <!-- SEARCH -->
                    <div class="search-box">

                        <input type="text"
                               class="form-control"
                               placeholder="Buscar clínica o especialidad...">

                        <select class="form-select">
                            <option>Especialidad</option>
                            <option>Cardiología</option>
                            <option>Pediatría</option>
                            <option>Neurología</option>
                            <option>Dermatología</option>
                        </select>

                        <button class="btn btn-search">
                            <i class="bi bi-search"></i>
