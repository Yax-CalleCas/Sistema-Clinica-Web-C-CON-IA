                                <div class="card-body">

                                    <div class="d-flex justify-content-between align-items-start mb-3">

                                        <div>
                                            <h4 class="clinic-name">
                                                Medical Center Norte
                                            </h4>

                                            <div class="clinic-location mt-2">
                                                <i class="bi bi-geo-alt"></i>
                                                Víctor Larco
                                            </div>
                                        </div>

                                        <div class="rating">
                                            ★ 4.8
                                        </div>

                                    </div>

                                    <p class="text-muted">
