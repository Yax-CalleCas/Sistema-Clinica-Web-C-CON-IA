                                        <small class="text-success fw-semibold">
                                            Disponible mañana
                                        </small>

                                        <button class="btn btn-clinic">
                                            Ver clínica
                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- CARD 3 -->
                        <div class="col-md-6">

                            <div class="clinic-card">

                                <img src="https://images.unsplash.com/photo-1538108149393-fbbd81895907?q=80&w=1400&auto=format&fit=crop"
                                     class="w-100">

                                <div class="card-body">

                                    <div class="d-flex justify-content-between align-items-start mb-3">

                                        <div>
                                            <h4 class="clinic-name">
                                                Centro Médico Primavera
                                            </h4>

                                            <div class="clinic-location mt-2">
                                                <i class="bi bi-geo-alt"></i>
                                                La Esperanza
                                            </div>
                                        </div>

                                        <div class="rating">
                                            ★ 4.7
                                        </div>

                                    </div>

                                    <p class="text-muted">
                                        Servicios médicos especializados para toda la familia.
                                    </p>

                                    <div class="mb-4">
                                        <span class="specialty-badge">Ginecología</span>
                                        <span class="specialty-badge">Pediatría</span>
