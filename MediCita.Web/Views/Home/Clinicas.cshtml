@{
    Layout = null;
    ViewData["Title"] = "Bienvenido";
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

@{
    Layout = null;
    ViewData["Title"] = "Clínicas en Trujillo";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>

        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f4f8fc;
            color: #0f172a;
            overflow-x: hidden;
        }

        /* NAVBAR */
        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,.90);
            box-shadow: 0 2px 20px rgba(0,0,0,.05);
        }

        .navbar-brand {
            font-weight: 800;
            color: #2563eb !important;
            font-size: 1.5rem;
        }

        /* HERO */
        .hero {
            padding: 120px 0 90px;
            background: linear-gradient(rgba(15,23,42,.75), rgba(15,23,42,.75)), url('https://images.unsplash.com/photo-1586773860418-d37222d8fce3?q=80&w=1600&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            color: white;
            position: relative;
        }

            .hero h1 {
                font-size: 4rem;
                font-weight: 800;
                line-height: 1.1;
            }

            .hero p {
                color: rgba(255,255,255,.85);
                font-size: 1.15rem;
                max-width: 700px;
                line-height: 1.8;
            }

        .search-box {
            background: white;
            padding: 12px;
            border-radius: 25px;
            display: flex;
            gap: 10px;
            box-shadow: 0 15px 35px rgba(0,0,0,.12);
            margin-top: 40px;
        }

            .search-box input,
            .search-box select {
                border: none;
                box-shadow: none !important;
                padding: 14px;
                border-radius: 16px;
            }

        .btn-search {
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            border: none;
            color: white;
            border-radius: 18px;
            padding: 14px 28px;
            font-weight: 600;
            transition: .3s ease;
        }

            .btn-search:hover {
                transform: scale(1.03);
                color: white;
            }

        /* SECTION */
        .section-padding {
            padding: 90px 0;
        }

        .section-title {
            font-size: 2.6rem;
            font-weight: 800;
        }

        .section-subtitle {
            color: #64748b;
            font-size: 1.05rem;
        }

        /* FILTERS */
        .filter-card {
            background: white;
            border-radius: 28px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
            position: sticky;
            top: 100px;
        }

        .filter-title {
            font-weight: 700;
            margin-bottom: 20px;
        }

        /* CLINIC CARD */
        .clinic-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            border: none;
            transition: .35s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
            height: 100%;
        }

            .clinic-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(0,0,0,.10);
            }

            .clinic-card img {
                height: 230px;
                object-fit: cover;
            }

            .clinic-card .card-body {
                padding: 30px;
            }

        .clinic-name {
            font-size: 1.4rem;
            font-weight: 700;
        }

        .clinic-location {
            color: #64748b;
            font-size: .95rem;
        }

        .rating {
            color: #f59e0b;
            font-weight: 700;
        }

        .specialty-badge {
            background: #eff6ff;
            color: #2563eb;
            padding: 10px 16px;
            border-radius: 50px;
            font-size: .85rem;
            font-weight: 600;
            display: inline-block;
            margin: 5px;
        }

        .btn-clinic {
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            border: none;
            color: white;
            padding: 12px 24px;
            border-radius: 50px;
            font-weight: 600;
            transition: .3s ease;
        }

            .btn-clinic:hover {
                transform: scale(1.05);
                color: white;
            }

        /* STATS */
        .stats-card {
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: white;
            border-radius: 35px;
            padding: 50px;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 800;
        }

        /* FEATURES */
        .feature-card {
            background: white;
            border-radius: 28px;
            padding: 40px 30px;
            text-align: center;
            height: 100%;
            transition: .3s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
        }

            .feature-card:hover {
                transform: translateY(-10px);
            }

        .feature-icon {
            width: 90px;
            height: 90px;
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: white;
            font-size: 2rem;
            margin-bottom: 25px;
        }

        /* FOOTER */
        footer {
            background: #0f172a;
            color: rgba(255,255,255,.75);
            padding: 50px 0;
        }

        /* RESPONSIVE */
    

        {
            font-size: 2.7rem;
        }

        .search-box {
            flex-direction: column;
        }

        .section-title {
            font-size: 2rem;
        }

        }</style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">

            <a class="navbar-brand" href="#">
                <i class="bi bi-heart-pulse-fill"></i>
                MediTrujillo
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
