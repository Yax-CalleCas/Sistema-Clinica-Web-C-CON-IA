@{
    Layout = null;
    ViewData["Title"] = "Bienvenido";
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}


@{
    Layout = null;
    ViewData["Title"] = "Quiénes Somos";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>

        * {
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #f8fbff;
            color: #1e293b;
            overflow-x: hidden;
        }

        /* HERO */
        .hero-section {
            background: linear-gradient(rgba(15, 23, 42, .70), rgba(15, 23, 42, .70)), url('https://images.unsplash.com/photo-1586773860418-d37222d8fce3?q=80&w=1400&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            min-height: 75vh;
            display: flex;
            align-items: center;
            position: relative;
        }

        .hero-content h1 {
            font-size: 4rem;
            font-weight: 800;
            color: white;
        }

        .hero-content p {
            color: rgba(255,255,255,.85);
            font-size: 1.15rem;
            max-width: 700px;
            line-height: 1.8;
        }

        .btn-modern {
            background: linear-gradient(135deg, #0d6efd, #4f46e5);
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 600;
            transition: .3s ease;
            box-shadow: 0 10px 25px rgba(79,70,229,.25);
        }

            .btn-modern:hover {
                transform: translateY(-3px);
                color: white;
            }

        /* SECTION */
        .section-padding {
            padding: 100px 0;
        }

        .section-title {
            font-size: 2.7rem;
            font-weight: 800;
            color: #0f172a;
        }

        .section-subtitle {
            color: #64748b;
            font-size: 1.05rem;
            line-height: 1.9;
        }

        /* CARDS */
        .info-card {
            border: none;
            border-radius: 28px;
            background: white;
            padding: 40px 30px;
            transition: .35s ease;
            height: 100%;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
        }

            .info-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 18px 40px rgba(0,0,0,.10);
            }

        .info-icon {
            width: 85px;
            height: 85px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 25px;
            background: linear-gradient(135deg, #0d6efd, #4f46e5);
            color: white;
            font-size: 2rem;
            margin-bottom: 25px;
            box-shadow: 0 10px 20px rgba(79,70,229,.20);
        }

        .info-card h4 {
            font-weight: 700;
            margin-bottom: 15px;
        }

        .info-card p {
            color: #64748b;
            line-height: 1.8;
        }

        /* STATS */
        .stats-section {
            background: linear-gradient(135deg, #0d6efd, #4f46e5);
            color: white;
            border-radius: 40px;
            padding: 60px 30px;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 800;
        }

        .stat-text {
            opacity: .9;
            font-size: 1rem;
        }

        /* VALUES */
        .value-item {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }

            .value-item i {
                font-size: 1.8rem;
                color: #4f46e5;
            }

            .value-item h5 {
                font-weight: 700;
            }

            .value-item p {
                color: #64748b;
                margin-bottom: 0;
            }

        /* TEAM */
        .team-card {
            background: white;
            border-radius: 28px;
            overflow: hidden;
            border: none;
            transition: .3s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
        }

            .team-card:hover {
                transform: translateY(-10px);
            }

            .team-card img {
                height: 320px;
                object-fit: cover;
            }

            .team-card .card-body {
                padding: 30px;
            }

            .team-card h5 {
                font-weight: 700;
            }

            .team-card span {
                color: #4f46e5;
                font-weight: 600;
            }

        /* CTA */
        .cta-section {
            background: white;
            border-radius: 35px;
            padding: 70px 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,.06);
        }

        }

        {
            .hero-content h1

        {
            font-size: 2.7rem;
        }

        .section-title {
            font-size: 2rem;
        }

        .hero-section {
            text-align: center;
            padding: 60px 20px;
        }

        }
    </style>
</head>
<body>

    <!-- HERO -->
    <section class="hero-section">
        <div class="container">
            <div class="hero-content">

                <span class="badge bg-primary px-4 py-2 rounded-pill mb-4 fs-6">
                    Clínica Premium
                </span>

                <h1>
                    Comprometidos con tu salud y bienestar
                </h1>

                <p class="mt-4 mb-5">
                    Somos una institución médica moderna enfocada en brindar atención integral, tecnología avanzada y profesionales altamente capacitados para cuidar de ti y tu familia.
                </p>

                <a href="#historia" class="btn btn-modern">
                    Conócenos más
                </a>

            </div>
        </div>
    </section>

    <!-- HISTORIA -->
    <section class="section-padding" id="historia">
        <div class="container">

            <div class="row align-items-center g-5">

                <div class="col-lg-6">
                    <img src="https://images.unsplash.com/photo-1516549655169-df83a0774514?q=80&w=1200&auto=format&fit=crop"
                         class="img-fluid rounded-5 shadow-lg">
                </div>

                <div class="col-lg-6">

                    <h2 class="section-title mb-4">
                        Nuestra Historia
                    </h2>

                    <p class="section-subtitle">
                        Desde nuestros inicios, hemos trabajado con el objetivo de ofrecer servicios médicos de alta calidad, priorizando siempre la seguridad, confianza y bienestar de nuestros pacientes.
                    </p>

                    <p class="section-subtitle mt-4">
                        Contamos con infraestructura moderna, equipamiento tecnológico y un equipo humano comprometido con brindar experiencias positivas en cada atención.
                    </p>

                    <div class="mt-5 d-flex gap-4 flex-wrap">

                        <div>
                            <h3 class="fw-bold text-primary">15+</h3>
                            <p class="text-muted">Años de experiencia</p>
                        </div>

                        <div>
                            <h3 class="fw-bold text-primary">50K+</h3>
                            <p class="text-muted">Pacientes atendidos</p>
                        </div>

                        <div>
                            <h3 class="fw-bold text-primary">24/7</h3>
                            <p class="text-muted">Atención continua</p>
                        </div>

                    </div>

                </div>

            </div>

        </div>
    </section>

    <!-- MISION VISION -->
    <section class="section-padding pt-0">
        <div class="container">

            <div class="row g-4">

                <div class="col-lg-4">
                    <div class="info-card">

                        <div class="info-icon">
                            <i class="bi bi-heart-pulse"></i>
                        </div>

                        <h4>Misión</h4>

                        <p>
                            Brindar servicios de salud integrales con altos estándares de calidad, tecnología moderna y atención humanizada.
                        </p>

                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="info-card">

                        <div class="info-icon">
                            <i class="bi bi-eye"></i>
                        </div>

                        <h4>Visión</h4>

                        <p>
                            Ser reconocidos como una de las clínicas líderes del país por nuestra excelencia médica e innovación constante.
                        </p>

                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="info-card">

                        <div class="info-icon">
                            <i class="bi bi-stars"></i>
                        </div>

                        <h4>Valores</h4>

                        <p>
                            Ética, compromiso, empatía, innovación y responsabilidad son pilares fundamentales de nuestra institución.
                        </p>

                    </div>
                </div>

            </div>

        </div>
    </section>

    <!-- ESTADISTICAS -->
    <section class="container mb-5">

        <div class="stats-section text-center">

            <div class="row g-4">

                <div class="col-md-3">
                    <div class="stat-number">120+</div>
                    <div class="stat-text">Especialistas médicos</div>
                </div>

                <div class="col-md-3">
                    <div class="stat-number">24h</div>
                    <div class="stat-text">Emergencias activas</div>
                </div>

                <div class="col-md-3">
                    <div class="stat-number">98%</div>
                    <div class="stat-text">Pacientes satisfechos</div>
                </div>

                <div class="col-md-3">
                    <div class="stat-number">30+</div>
                    <div class="stat-text">Especialidades médicas</div>
                </div>

            </div>

        </div>

    </section>

    <!-- VALORES -->
    <section class="section-padding">
        <div class="container">

            <div class="row align-items-center g-5">

                <div class="col-lg-6">

                    <h2 class="section-title mb-5">
                        ¿Por qué elegirnos?
                    </h2>

                    <div class="value-item">
                        <i class="bi bi-shield-check"></i>

                        <div>
                            <h5>Atención segura</h5>
                            <p>
                                Protocolos modernos y tecnología avanzada para garantizar seguridad médica.
                            </p>
                        </div>
                    </div>

                    <div class="value-item">
                        <i class="bi bi-people"></i>

                        <div>
                            <h5>Equipo especializado</h5>
                            <p>
                                Profesionales altamente capacitados y comprometidos contigo.
                            </p>
                        </div>
                    </div>

                    <div class="value-item">
                        <i class="bi bi-cpu"></i>

                        <div>
                            <h5>Tecnología moderna</h5>
                            <p>
                                Equipamiento médico actualizado para diagnósticos más precisos.
                            </p>
                        </div>
                    </div>

                </div>

                <div class="col-lg-6">
                    <img src="https://images.unsplash.com/photo-1579684385127-1ef15d508118?q=80&w=1200&auto=format&fit=crop"
                         class="img-fluid rounded-5 shadow-lg">
                </div>

            </div>

        </div>
    </section>

    <!-- EQUIPO -->
    <section class="section-padding bg-light">

        <div class="container">

            <div class="text-center mb-5">

                <h2 class="section-title">
                    Nuestro equipo médico
                </h2>

                <p class="section-subtitle mt-3">
                    Profesionales comprometidos con brindar una atención de primer nivel.
                </p>

            </div>

            <div class="row g-4">

                <div class="col-lg-4 col-md-6">
                    <div class="team-card">

                        <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?q=80&w=1200&auto=format&fit=crop"
                             class="w-100">

                        <div class="card-body text-center">
                            <h5>Dr. Carlos Mendoza</h5>
                            <span>Cardiología</span>
                        </div>

                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="team-card">

                        <img src="https://images.unsplash.com/photo-1594824476967-48c8b964273f?q=80&w=1200&auto=format&fit=crop"
                             class="w-100">

                        <div class="card-body text-center">
                            <h5>Dra. Mariana López</h5>
                            <span>Pediatría</span>
                        </div>

                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="team-card">

                        <img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=1200&auto=format&fit=crop"
                             class="w-100">

                        <div class="card-body text-center">
                            <h5>Dr. José Ramírez</h5>
                            <span>Neurología</span>
                        </div>

                    </div>
                </div>

            </div>

        </div>

    </section>



    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
