@{
    Layout = null;
    ViewData["Title"] = "Bienvenido";
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRP Salud</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/Home.css" rel="stylesheet" />

  
</head>
<body>
    <!-- Navbar Actualizado - Todo en HomeController -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3 text-dark" href="/">
                <span style="color: #0d9488;">CRP</span> Salud
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                 
            
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Clinicas" class="nav-link fw-medium">Clínicas</a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Nosotros" class="nav-link fw-medium">Sobre Nosotros</a>
                    </li>

                    @if (isAuthenticated)
                    {
                        <li class="nav-item ms-3">
                            <a asp-controller="Paciente" asp-action="Index" class="btn btn-teal rounded-pill px-4 py-2">
                                <i class="bi bi-person-circle me-2"></i>Mi Cuenta
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-3">
                            <button class="btn btn-outline-secondary rounded-pill px-4 py-2"
                                    data-bs-toggle="modal" data-bs-target="#loginModal">
                                Iniciar Sesión
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="hero-container">
        <div id="heroCarousel" class="carousel slide h-100" data-bs-ride="carousel">
            <div class="carousel-inner h-100">
                <div class="carousel-item active h-100">
                    <img src="https://masbonita.com.mx/wp-content/uploads/2023/07/Pasillo-1.jpg" class="d-block w-100 h-100" alt="Sistema integral de salud">
                    <div class="hero-overlay"></div>
                    <div class="carousel-caption">
                        <h1 class="display-3 fw-bold text-white mb-3">Tu Salud en Buenas Manos</h1>
                        <p class="lead text-white mb-4" style="max-width: 580px;">
                            Gestiona tus citas, accede a tu historial médico y conecta con los mejores especialistas.
                        </p>
                        <button type="button" class="btn btn-teal btn-lg rounded-pill px-5 py-3"
                                data-bs-toggle="modal" data-bs-target="#loginModal">
                            COMENZAR AHORA
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Servicios Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="section-title display-5">Nuestros Servicios</h2>
                <p class="text-muted mt-3 fs-5">Soluciones integrales para el cuidado de tu salud</p>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card card-service shadow-sm text-center p-4">
                        <div class="mb-4">
                            <i class="bi bi-calendar2-heart fs-1 text-teal"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Gestión de Citas</h4>
                        <p class="text-muted">Agenda, reprograma y gestiona tus citas médicas de forma rápida y sencilla.</p>
                        @if (isAuthenticated)
                        {
                            <a asp-controller="Paciente" asp-action="Index" class="btn btn-teal rounded-pill w-100 mt-3">Mis Citas</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-teal rounded-pill w-100 mt-3"
                                    data-bs-toggle="modal" data-bs-target="#loginModal">
                                Iniciar Sesión
                            </button>
                        }
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card card-service shadow-sm text-center p-4">
                        <div class="mb-4">
                            <i class="bi bi-file-medical fs-1 text-teal"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Historial Médico</h4>
                        <p class="text-muted">Accede digitalmente a tu historial clínico completo y resultados de exámenes.</p>
                        <button type="button" class="btn btn-outline-teal rounded-pill w-100 mt-3"
                                data-bs-toggle="modal" data-bs-target="#loginModal">
                            Acceder
                        </button>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card card-service shadow-sm text-center p-4">
                        <div class="mb-4">
                            <i class="bi bi-person-video fs-1 text-teal"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Telemedicina</h4>
                        <p class="text-muted">Consulta con especialistas desde cualquier lugar mediante videollamadas seguras.</p>
                        <button type="button" class="btn btn-outline-teal rounded-pill w-100 mt-3"
                                data-bs-toggle="modal" data-bs-target="#loginModal">
                            Consultar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <partial name="_LoginModals" />

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const isAuthenticated = @Json.Serialize(isAuthenticated);

        document.addEventListener('click', (e) => {
            const link = e.target.closest('a[href*="Venta/Catalogo"]');
            if (link && !isAuthenticated) {
                e.preventDefault();
                new bootstrap.Modal(document.getElementById('requireLoginModal')).show();
            }
        });
    </script>

    @if (TempData["ExitoRegistro"] != null || TempData["ErrorLogin"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                Swal.fire({
                    icon: '@(TempData["ExitoRegistro"] != null ? "success" : "error")',
                    title: '@(TempData["ExitoRegistro"] != null ? "¡Éxito!" : "Error")',
                    text: '@(TempData["ExitoRegistro"] ?? TempData["ErrorLogin"])',
                    confirmButtonColor: '#0d9488'
                }).then(() => {
                    new bootstrap.Modal(document.getElementById('loginModal')).show();
                });
            });
        </script>
    }
</body>
</html>