-- Define roles del sistema
CREATE TABLE tb_Roles (
    IdRol INT PRIMARY KEY IDENTITY(1,1),
    NombreRol VARCHAR(50) NOT NULL UNIQUE
);

-- Almacena usuarios registrados
CREATE TABLE tb_Usuarios (
    IdUsuario INT IDENTITY(1,1) PRIMARY KEY,
    NombreCompleto NVARCHAR(100) NOT NULL,
    DNI VARCHAR(15),                                -- Identificación personal
    Correo NVARCHAR(100) NOT NULL UNIQUE,
    Clave NVARCHAR(200) NOT NULL,
    IdRol INT NOT NULL,
    Activo BIT NOT NULL DEFAULT 1,
    FechaRegistro DATETIME NOT NULL DEFAULT GETDATE(),
    CONSTRAINT FK_Usuarios_Rol FOREIGN KEY (IdRol) REFERENCES tb_Roles(IdRol)
);

-- Catálogo especialidades médicas
CREATE TABLE tb_Especialidades (
    IdEspecialidad INT PRIMARY KEY IDENTITY(1,1),
    NombreEspec VARCHAR(80) NOT NULL,
    Descripcion VARCHAR(300)
);


-- Información profesionales médicos
CREATE TABLE tb_Medicos (
    IdMedico INT PRIMARY KEY IDENTITY(1,1),
    IdUsuario INT UNIQUE NOT NULL,
    IdEspecialidad INT,
    CMP VARCHAR(20) NOT NULL,
    RNE VARCHAR(20) NULL,                            -- Registro especialidad
    Telefono VARCHAR(15),
    PrecioConsulta DECIMAL(10,2) NOT NULL DEFAULT 80.00,
    DuracionMinutos INT NOT NULL DEFAULT 30,
    TipoServicio VARCHAR(100),
    HorarioAtencionInicio TIME,
    HorarioAtencionFin TIME,
    CONSTRAINT FK_Medicos_Usuario FOREIGN KEY (IdUsuario) REFERENCES tb_Usuarios(IdUsuario),
    CONSTRAINT FK_Medicos_Especialidad FOREIGN KEY (IdEspecialidad) REFERENCES tb_Especialidades(IdEspecialidad)
);

ALTER TABLE tb_Medicos
ADD ImagenUrl NVARCHAR(500) NULL;

-- Registro citas médicas
CREATE TABLE tb_Citas (
    IdCita INT PRIMARY KEY IDENTITY(1,1),
    IdPaciente INT NOT NULL,
    IdMedico INT NOT NULL,
    FechaCita DATETIME NOT NULL,
    HoraInicio TIME NULL,                             -- Hora inicio cita
    HoraFin TIME NULL,                                -- Hora fin cita
    MontoPagar DECIMAL(10,2) NULL,                    -- Costo consulta
    Estado CHAR(1) DEFAULT 'P' CHECK (Estado IN ('P','A','C')),
    CONSTRAINT FK_Citas_Paciente FOREIGN KEY (IdPaciente) REFERENCES tb_Usuarios(IdUsuario),
    CONSTRAINT FK_Citas_Medico FOREIGN KEY (IdMedico) REFERENCES tb_Medicos(IdMedico)
);

-- Horarios asignados médicos
CREATE TABLE tb_HorariosMedico (
    IdHorario INT PRIMARY KEY IDENTITY(1,1),
    IdMedico INT NOT NULL,
    HoraInicio TIME NOT NULL,
    HoraFin TIME NOT NULL,
    Disponible BIT NOT NULL DEFAULT 1,
    CONSTRAINT FK_Horarios_Medico FOREIGN KEY (IdMedico) REFERENCES tb_Medicos(IdMedico)
);
