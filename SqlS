CREATE OR ALTER PROCEDURE sp_Chatbot_ObtenerContexto
AS
BEGIN
    SET NOCOUNT ON;

    -- =====================================================
    -- MEDICOS PUBLICOS
    -- SOLO INFORMACION SEGURA PARA EL CHATBOT
    -- =====================================================
    SELECT 
        m.IdMedico,
        u.NombreCompleto,
        e.NombreEspec,
        m.PrecioConsulta,
        m.TipoServicio,
        CONVERT(VARCHAR, m.HorarioAtencionInicio, 108) 
            AS HoraInicio,
        CONVERT(VARCHAR, m.HorarioAtencionFin, 108) 
            AS HoraFin,
        ISNULL(
            m.ImagenUrl,
            '/img/default-doctor.png'
        ) AS Imagen
    FROM tb_Medicos m
    INNER JOIN tb_Usuarios u
        ON m.IdUsuario = u.IdUsuario
    INNER JOIN tb_Especialidades e
        ON m.IdEspecialidad = e.IdEspecialidad
    WHERE u.Activo = 1;

    -- =====================================================
    -- MEDICAMENTOS PUBLICOS
    -- =====================================================
    SELECT
        IdMedicamento,
        Nombre,
        Laboratorio,
        Precio,
        Stock,
        Categoria,
        ISNULL(Promocion, '') AS Promocion,
        ISNULL(
            ImagenUrl,
            '/img/default-pill.png'
        ) AS Imagen
    FROM tb_Medicamentos
    WHERE Stock > 0;

    -- =====================================================
    -- HORARIOS DISPONIBLES
    -- =====================================================
    SELECT TOP 50
        hm.IdHorario,
        u.NombreCompleto AS Medico,
        hm.Fecha,
        CONVERT(VARCHAR, hm.HoraInicio, 108)
            AS HoraInicio,
        CONVERT(VARCHAR, hm.HoraFin, 108)
            AS HoraFin
    FROM tb_HorariosMedico hm
    INNER JOIN tb_Medicos m
        ON hm.IdMedico = m.IdMedico
    INNER JOIN tb_Usuarios u
        ON m.IdUsuario = u.IdUsuario
    WHERE hm.Disponible = 1
    ORDER BY hm.Fecha, hm.HoraInicio;

END
GO


