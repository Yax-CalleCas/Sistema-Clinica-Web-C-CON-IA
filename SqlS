CREATE OR ALTER PROCEDURE usp_RegistrarVentaCompleta
    @IdUsuario INT,
    @MetodoPago VARCHAR(30), -- Nuevo parámetro para capturar el método de pago
    @Detalles TVP_DetalleVenta READONLY
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRAN;

    DECLARE @IdVenta INT;

    BEGIN TRY
        -- 1. Insertar Cabecera (con Método de Pago)
        INSERT INTO tb_Ventas(IdPaciente, SubTotal, IGV, TotalFinal, MetodoPago)
        VALUES (@IdUsuario, 0, 0, 0, @MetodoPago);

        SET @IdVenta = SCOPE_IDENTITY();

        -- 2. Insertar detalles calculando descuentos
        INSERT INTO tb_DetalleVenta(
            IdVenta, IdMedicamento, Cantidad,
            PrecioUnitario, SubTotal,
            NombreMedicamento, ImagenUrl, Promocion
        )
        SELECT
            @IdVenta,
            d.IdMedicamento,
            d.Cantidad,
            d.Precio,
            (d.Precio * d.Cantidad) *
            (1 - 
                CASE 
                    WHEN d.Promocion LIKE '%\%%' ESCAPE '\' 
                         AND ISNUMERIC(REPLACE(d.Promocion,'%','')) = 1
                    THEN CAST(REPLACE(d.Promocion,'%','') AS DECIMAL(5,2)) / 100
                    ELSE 0
                END
            ),
            d.Nombre,
            d.ImagenUrl,
            ISNULL(d.Promocion,'')
        FROM @Detalles d;

        -- 3. Actualizar stock de medicamentos
        UPDATE m
        SET m.Stock = m.Stock - d.Cantidad
        FROM tb_Medicamentos m
        INNER JOIN @Detalles d ON m.IdMedicamento = d.IdMedicamento;

        -- 4. Calcular y actualizar Totales en la cabecera
        DECLARE @GranSubTotal DECIMAL(12,2);
        SELECT @GranSubTotal = SUM(SubTotal) FROM tb_DetalleVenta WHERE IdVenta = @IdVenta;

        UPDATE tb_Ventas
        SET
            SubTotal = @GranSubTotal,
            IGV = @GranSubTotal * 0.18,
            TotalFinal = @GranSubTotal * 1.18
        WHERE IdVenta = @IdVenta;

        -- 5. LIMPIAR CARRITO TEMPORAL (PERSISTENCIA)

        DELETE FROM tb_CarritoTemporal 
        WHERE IdUsuario = @IdUsuario;

        COMMIT;

        -- Retornar resultado de la transacción
        SELECT 
            v.IdVenta,
            v.SubTotal,
            v.IGV,
            v.TotalFinal,
            v.MetodoPago
        FROM tb_Ventas v
        WHERE v.IdVenta = @IdVenta;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        THROW;
    END CATCH
END;
GO

create or alter procedure usp_SincronizarCarrito
    @IdUsuario INT,
    @IdMedicamento INT,
    @Cantidad INT
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (SELECT 1 FROM tb_CarritoTemporal 
               WHERE IdUsuario = @IdUsuario AND IdMedicamento = @IdMedicamento)
    BEGIN
        -- Actualizar: Si la nueva cantidad es > 0 actualiza, sino elimina
        IF (SELECT Cantidad + @Cantidad FROM tb_CarritoTemporal 
            WHERE IdUsuario = @IdUsuario AND IdMedicamento = @IdMedicamento) > 0
        BEGIN
            UPDATE tb_CarritoTemporal
            SET Cantidad = Cantidad + @Cantidad,
                FechaAgregado = GETDATE()
            WHERE IdUsuario = @IdUsuario AND IdMedicamento = @IdMedicamento;
        END
        ELSE
        BEGIN
            DELETE FROM tb_CarritoTemporal 
            WHERE IdUsuario = @IdUsuario AND IdMedicamento = @IdMedicamento;
        END
    END
    ELSE
    BEGIN
        -- Solo insertar si la cantidad es positiva
        IF @Cantidad > 0
        BEGIN
            INSERT INTO tb_CarritoTemporal (IdUsuario, IdMedicamento, Cantidad, FechaAgregado)
            VALUES (@IdUsuario, @IdMedicamento, @Cantidad, GETDATE());
        END
    END
END;
GO

