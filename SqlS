CREATE OR ALTER PROCEDURE usp_ValidarDatosMedico
    @DNI VARCHAR(20),
    @Correo VARCHAR(100),
    @CMP VARCHAR(20),
    @IdMedico INT = NULL -- Opcional: Para excluir al propio médico en caso de edición
AS
BEGIN
    SET NOCOUNT ON;

    -- 1. Validar Correo (en la tabla de Usuarios)
    IF EXISTS (
        SELECT 1 FROM tb_Usuarios 
        WHERE Correo = @Correo 
        AND (@IdMedico IS NULL OR IdUsuario <> (SELECT IdUsuario FROM tb_Medicos WHERE IdMedico = @IdMedico))
    )
    BEGIN
        SELECT 'El correo electrónico ya está registrado por otro usuario.' AS Mensaje;
        RETURN;
    END

    -- 2. Validar DNI (en la tabla de Usuarios)
    IF EXISTS (
        SELECT 1 FROM tb_Usuarios
        WHERE DNI = @DNI 
        AND (@IdMedico IS NULL OR IdUsuario <> (SELECT IdUsuario FROM tb_Medicos WHERE IdMedico = @IdMedico))
    )
    BEGIN
        SELECT 'El DNI ya pertenece a otro usuario registrado.' AS Mensaje;
        RETURN;
    END

    -- 3. Validar CMP (en la tabla de Médicos)
    IF EXISTS (
        SELECT 1 FROM tb_Medicos
        WHERE CMP = @CMP 
        AND (@IdMedico IS NULL OR IdMedico <> @IdMedico)
    )
    BEGIN
        SELECT 'El número de CMP ya se encuentra registrado.' AS Mensaje;
        RETURN;
    END

    -- Si llega aquí, todo está bien   
    SELECT NULL AS Mensaje;
END
