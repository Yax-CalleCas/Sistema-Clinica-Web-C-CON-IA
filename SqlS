--estadisticas para el panel del cliente 
CREATE OR ALTER PROCEDURE sp_EstadisticasPaciente
    @IdPaciente INT
AS
BEGIN
    SET NOCOUNT ON;

    -- Estadísticas de citas
    SELECT
        COUNT(*) AS TotalCitas,
        ISNULL(SUM(CASE WHEN Estado = 'P' THEN 1 ELSE 0 END),0) AS Pendientes,
        ISNULL(SUM(CASE WHEN Estado = 'A' THEN 1 ELSE 0 END),0) AS Atendidas,
        ISNULL(SUM(CASE WHEN Estado = 'C' THEN 1 ELSE 0 END),0) AS Canceladas
    INTO #Citas
    FROM tb_Citas
    WHERE IdPaciente = @IdPaciente;

    -- Estadísticas de compras
    SELECT
        ISNULL(COUNT(*),0) AS ComprasRealizadas,
        ISNULL(SUM(TotalFinal),0) AS TotalGastado
    INTO #Ventas
    FROM tb_Ventas
    WHERE IdPaciente = @IdPaciente;

    -- Combinar resultados y devolver
    SELECT
        c.TotalCitas,
        c.Pendientes,
        c.Atendidas,
        c.Canceladas,
        v.ComprasRealizadas,
        v.TotalGastado
    FROM #Citas c
    CROSS JOIN #Ventas v;
	 
    -- Limpiar tablas temporales
    DROP TABLE #Citas;
    DROP TABLE #Ventas;
END
GO


