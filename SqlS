-- Procedimientos para citas 
CREATE OR ALTER PROCEDURE sp_ReporteCitasPorFecha
(
    @FechaInicio DATE,
    @FechaFin DATE,
    @Estado CHAR(1) = NULL
)
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        c.IdCita,
        uPac.NombreCompleto AS Paciente,
        uMed.NombreCompleto AS Medico,
        m.CMP,
        e.NombreEspec AS Especialidad,
        c.FechaCita,
        c.HoraInicio,
        c.HoraFin,
        c.MontoPagar,
        c.Estado, 
        CASE c.Estado
            WHEN 'P' THEN 'Pendiente'
            WHEN 'A' THEN 'Atendida'
            WHEN 'C' THEN 'Cancelada'
        END AS EstadoDescripcion,
        n.Nota AS NotaCita,
        CASE 
            WHEN c.Estado = 'C' THEN n.Nota
            ELSE NULL
        END AS MotivoCancelacion
    FROM tb_Citas c
    INNER JOIN tb_Usuarios uPac ON c.IdPaciente = uPac.IdUsuario
    INNER JOIN tb_Medicos m ON c.IdMedico = m.IdMedico
    INNER JOIN tb_Usuarios uMed ON m.IdUsuario = uMed.IdUsuario
    LEFT JOIN tb_Especialidades e ON m.IdEspecialidad = e.IdEspecialidad
    OUTER APPLY (
        SELECT TOP 1 Nota
        FROM tb_CitaNotas n
        WHERE n.IdCita = c.IdCita
        ORDER BY n.FechaNota DESC
    ) n
    WHERE c.FechaCita >= @FechaInicio
      AND c.FechaCita <= @FechaFin 
      AND (@Estado IS NULL OR c.Estado = @Estado)
    ORDER BY c.FechaCita DESC, c.HoraInicio;
END
go

CREATE OR ALTER PROCEDURE sp_ReporteVentasPorFecha
(
    @FechaInicio DATE,
    @FechaFin DATE
)
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        v.IdVenta,
        u.NombreCompleto AS Paciente,
        v.FechaVenta,
        dv.NombreMedicamento,
        dv.Cantidad,
        dv.PrecioUnitario,
        dv.SubTotal,
        v.SubTotal AS VentaSubTotal,
        v.IGV,
        v.TotalFinal,
        v.MetodoPago,

        -- Extrae porcentaje desde texto tipo '10% OFF'
        CASE
            WHEN dv.Promocion LIKE '%[%]%'
                THEN TRY_CAST(
                        REPLACE(
                            LEFT(dv.Promocion, CHARINDEX('%', dv.Promocion) - 1),
                            '%',''
                        ) AS INT
                     )
            ELSE 0
        END AS PorcentajeDescuento

    FROM tb_Ventas v
    INNER JOIN tb_Usuarios u ON v.IdPaciente = u.IdUsuario
    INNER JOIN tb_DetalleVenta dv ON v.IdVenta = dv.IdVenta
    WHERE CAST(v.FechaVenta AS DATE)
          BETWEEN @FechaInicio AND @FechaFin
    ORDER BY v.FechaVenta DESC;
END
GO



