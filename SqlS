-- REGISTRAR USUARIO NORMAL (PACIENTE DESDE WEB) solo admite pacientes 

CREATE OR ALTER PROCEDURE usp_RegistrarUsuario
(
    @NombreCompleto NVARCHAR(100),
    @DNI VARCHAR(15) = NULL,
    @Correo NVARCHAR(100),
    @Clave NVARCHAR(200),
    @IdRol INT = 3
)
AS
BEGIN
    SET NOCOUNT ON;

    -- Validar correo duplicado
    IF EXISTS (SELECT 1 FROM tb_Usuarios WHERE Correo = @Correo)
    BEGIN
        SELECT -1 AS IdGenerado; -- Correo duplicado
        RETURN;
    END

    -- Validar DNI duplicado (solo si no es NULL)
    IF @DNI IS NOT NULL
       AND EXISTS (SELECT 1 FROM tb_Usuarios WHERE DNI = @DNI)
    BEGIN
        SELECT -2 AS IdGenerado; -- DNI duplicado
        RETURN;
    END

    INSERT INTO tb_Usuarios (NombreCompleto, DNI, Correo, Clave, IdRol)
    VALUES (@NombreCompleto, @DNI, @Correo, @Clave, @IdRol);

    SELECT SCOPE_IDENTITY() AS IdGenerado;
END
GO


