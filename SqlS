-- Notas asociadas citas
CREATE TABLE tb_CitaNotas (
    IdNota INT IDENTITY(1,1) PRIMARY KEY,
    IdCita INT NOT NULL,
    Nota NVARCHAR(500),
    FechaNota DATETIME DEFAULT GETDATE(),
