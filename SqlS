CREATE OR ALTER PROCEDURE usp_AdminCrearMedico
(
    @NombreCompleto NVARCHAR(100),
    @DNI VARCHAR(15) = NULL,
    @Correo NVARCHAR(100),
    @Clave NVARCHAR(200),
    @IdEspecialidad INT,
    @CMP VARCHAR(20),
    @RNE VARCHAR(20) = NULL,
    @Telefono VARCHAR(15) = NULL,
    @PrecioConsulta DECIMAL(10,2) = 80,
    @DuracionMinutos INT = 40,
    @TipoServicio VARCHAR(100) = NULL,
    @ImagenUrl NVARCHAR(500) = NULL,   
    @Activo BIT = 1
)
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRAN;

        -- Validar correo duplicado
        IF EXISTS (SELECT 1 FROM tb_Usuarios WHERE Correo = @Correo)
        BEGIN
            SELECT -1 AS IdGenerado;
            ROLLBACK;
            RETURN;
        END

        -- Crear usuario
        INSERT INTO tb_Usuarios (NombreCompleto, DNI, Correo, Clave, IdRol, Activo)
        VALUES (@NombreCompleto, @DNI, @Correo, @Clave, 2, @Activo);

        DECLARE @IdUsuario INT = SCOPE_IDENTITY();

        -- Crear médico
        INSERT INTO tb_Medicos
        (
            IdUsuario, IdEspecialidad, CMP, RNE, Telefono,
            PrecioConsulta, DuracionMinutos, TipoServicio,
            HorarioAtencionInicio, HorarioAtencionFin,
            ImagenUrl
        )
        VALUES
        (
            @IdUsuario, @IdEspecialidad, @CMP, @RNE, @Telefono,
            @PrecioConsulta, @DuracionMinutos, @TipoServicio,
            '08:00', '17:00',
            @ImagenUrl
        );

        DECLARE @IdMedico INT = SCOPE_IDENTITY();

        -- Generar horarios (7 días)
        DECLARE @i INT = 0;
        DECLARE @FechaInicio DATE = CAST(GETDATE() AS DATE);

        WHILE @i < 7
        BEGIN
            INSERT INTO tb_HorariosMedico (IdMedico, Fecha, HoraInicio, HoraFin, Disponible)
            SELECT
                @IdMedico,
                DATEADD(DAY, @i, @FechaInicio),
                HoraInicio,
                HoraFin,
                1
            FROM tb_HorariosPlantilla;

            SET @i += 1;
        END

        COMMIT;
        SELECT @IdUsuario AS IdGenerado;

    END TRY
    BEGIN CATCH
        ROLLBACK;
        SELECT -2 AS ErrorCode;
    END CATCH
END;
GO


CREATE OR ALTER PROCEDURE usp_AdminEditarMedico
(
    @IdMedico INT,
    @NombreCompleto NVARCHAR(100),
    @DNI VARCHAR(15) = NULL,
    @Correo NVARCHAR(100),
    @IdEspecialidad INT,
    @CMP VARCHAR(20),
    @RNE VARCHAR(20) = NULL,
    @Telefono VARCHAR(15) = NULL,
    @PrecioConsulta DECIMAL(10,2),
    @DuracionMinutos INT,
    @TipoServicio NVARCHAR(100),
    @ImagenUrl NVARCHAR(500),   
    @Activo BIT
)
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRAN;

        DECLARE @IdUsuario INT;

        SELECT @IdUsuario = IdUsuario
        FROM tb_Medicos
        WHERE IdMedico = @IdMedico;

        -- Validar correo duplicado
        IF EXISTS (
            SELECT 1 FROM tb_Usuarios
            WHERE Correo = @Correo AND IdUsuario <> @IdUsuario
        )
        BEGIN
            SELECT -1 AS ResultCode;
            ROLLBACK;
            RETURN;
        END

        -- Actualizar usuario
        UPDATE tb_Usuarios
        SET NombreCompleto = @NombreCompleto,
            DNI = @DNI,
            Correo = @Correo,
            Activo = @Activo
        WHERE IdUsuario = @IdUsuario;

        -- Actualizar médico
        UPDATE tb_Medicos
        SET IdEspecialidad = @IdEspecialidad,
            CMP = @CMP,
            RNE = @RNE,
            Telefono = @Telefono,
            PrecioConsulta = @PrecioConsulta,
            DuracionMinutos = @DuracionMinutos,
            TipoServicio = @TipoServicio,
            ImagenUrl = @ImagenUrl
        WHERE IdMedico = @IdMedico;

        COMMIT;
        SELECT 1 AS ResultCode;

    END TRY
    BEGIN CATCH
        ROLLBACK;
        SELECT -2 AS ResultCode;
    END CATCH
END;
GO



