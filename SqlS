--estadisticas del panel de admin
CREATE OR ALTER PROCEDURE usp_ObtenerEstadisticasDashboard
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE 
        @TotalPacientes INT,
        @TotalMedicos INT,
        @CitasHoy INT,
        @VentasMes DECIMAL(12,2),
        @TopMedicamentos NVARCHAR(MAX),
        @StockBajo INT,
        @MedicamentosStockBajo NVARCHAR(MAX);

    -- 1. Total Pacientes 
    SELECT @TotalPacientes = COUNT(*)
    FROM tb_Usuarios
    WHERE IdRol = 3; 

    -- 2. Total Médicos
    SELECT @TotalMedicos = COUNT(*)
    FROM tb_Medicos;

    -- 3. Citas del día (Optimizando el filtro de fecha)
    SELECT @CitasHoy = COUNT(*)
    FROM tb_Citas
    WHERE CAST(FechaCita AS DATE) = CAST(GETDATE() AS DATE);

    -- 4. Ventas del mes actual
    SELECT @VentasMes = ISNULL(SUM(TotalFinal), 0)
    FROM tb_Ventas
    WHERE MONTH(FechaVenta) = MONTH(GETDATE())
      AND YEAR(FechaVenta) = YEAR(GETDATE());

    -- 5. Top 5 medicamentos más vendidos (JSON)
    SELECT @TopMedicamentos = (
        SELECT TOP 5 
            m.Nombre,
            SUM(d.Cantidad) AS TotalVendido
        FROM tb_DetalleVenta d
        INNER JOIN tb_Medicamentos m ON m.IdMedicamento = d.IdMedicamento
        GROUP BY m.Nombre
        ORDER BY TotalVendido DESC
        FOR JSON PATH
    );

    -- 6. Conteo de productos con stock bajo (Menos de 10 unidades)
    SELECT @StockBajo = COUNT(*)
    FROM tb_Medicamentos
    WHERE Stock < 10;

    -- 7. Lista detallada de stock bajo (JSON)
    SELECT @MedicamentosStockBajo = (
        SELECT 
            Nombre,
            Stock
        FROM tb_Medicamentos
        WHERE Stock < 10
        FOR JSON PATH
    );

    -- RESULTADO FINAL
    SELECT 
        ISNULL(@TotalPacientes, 0) AS TotalPacientes,
        ISNULL(@TotalMedicos, 0) AS TotalMedicosRegistrados,
        ISNULL(@CitasHoy, 0) AS CitasHoy,
        ISNULL(@VentasMes, 0) AS VentasMesActual,
        ISNULL(@TopMedicamentos, '[]') AS TopMedicamentosJson,
        ISNULL(@StockBajo, 0) AS ProductosStockBajo,
        ISNULL(@MedicamentosStockBajo, '[]') AS MedicamentosStockBajoJson;
END;
GO

CREATE OR ALTER PROCEDURE usp_ValidarUsuario
    @Correo NVARCHAR(100),
    @Clave NVARCHAR(200)
AS
BEGIN
    SET NOCOUNT ON;

    SELECT 
        u.IdUsuario,
        u.NombreCompleto,
        u.Correo,
        u.IdRol,
        r.NombreRol,
        m.IdMedico   
    FROM tb_Usuarios u
    INNER JOIN tb_Roles r ON u.IdRol = r.IdRol
    LEFT JOIN tb_Medicos m ON m.IdUsuario = u.IdUsuario  
    WHERE 
        u.Correo = @Correo
        AND u.Clave = @Clave
        AND u.Activo = 1;
END
