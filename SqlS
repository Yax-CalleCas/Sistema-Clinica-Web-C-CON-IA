    @NombreCompleto NVARCHAR(100),
    @DNI VARCHAR(15) = NULL,
    @Correo NVARCHAR(100),
    @Clave NVARCHAR(200),
    @Activo BIT = 1
)
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (SELECT 1 FROM tb_Usuarios WHERE Correo = @Correo)
    BEGIN
        SELECT -1 AS IdGenerado;
        RETURN;
    END

    INSERT INTO tb_Usuarios (NombreCompleto, DNI, Correo, Clave, IdRol, Activo)
    VALUES (@NombreCompleto, @DNI, @Correo, @Clave, 3, @Activo); -- Rol Paciente

    SELECT SCOPE_IDENTITY() AS IdGenerado;
END
