CREATE OR ALTER PROCEDURE usp_ListarMedicosDisponibles
    @IdEspecialidad INT = NULL,
    @Fecha DATE = NULL
AS
BEGIN
    SET NOCOUNT ON;

    SELECT DISTINCT
        m.IdMedico,
        u.NombreCompleto AS NombreMedico,
        m.CMP,
        e.NombreEspec,
        m.PrecioConsulta,
        m.TipoServicio,
        m.ImagenUrl,           
        h.IdHorario,
        h.HoraInicio,
        h.HoraFin,
        h.Fecha
    FROM tb_Medicos m
    INNER JOIN tb_Usuarios u 
        ON u.IdUsuario = m.IdUsuario
    LEFT JOIN tb_Especialidades e 
        ON e.IdEspecialidad = m.IdEspecialidad
    LEFT JOIN tb_HorariosMedico h 
        ON h.IdMedico = m.IdMedico
    WHERE (@IdEspecialidad IS NULL OR m.IdEspecialidad = @IdEspecialidad)
      AND (@Fecha IS NULL OR h.Fecha = @Fecha)
      AND (h.Disponible = 1 OR h.IdHorario IS NULL)
    ORDER BY u.NombreCompleto, h.HoraInicio;
END
GO

CREATE OR ALTER PROCEDURE sp_ListarCitas
(
    @IdUsuario INT,       -- Id del paciente o médico
    @Rol NVARCHAR(20)     -- 'Paciente' o 'Medico'
)
AS
BEGIN
    SET NOCOUNT ON;

    IF @Rol = 'Paciente'
    BEGIN
        SELECT c.IdCita, c.IdMedico, m.CMP, m.IdEspecialidad, e.NombreEspec,
               c.FechaCita, c.HoraInicio, c.HoraFin, c.MontoPagar, c.Estado
        FROM tb_Citas c
        INNER JOIN tb_Medicos m ON c.IdMedico = m.IdMedico
        LEFT JOIN tb_Especialidades e ON m.IdEspecialidad = e.IdEspecialidad
        WHERE c.IdPaciente = @IdUsuario
        ORDER BY c.FechaCita, c.HoraInicio;
    END
    ELSE IF @Rol = 'Medico'
    BEGIN
        SELECT c.IdCita, c.IdPaciente, u.NombreCompleto AS Paciente, c.FechaCita,
               c.HoraInicio, c.HoraFin, c.MontoPagar, c.Estado
        FROM tb_Citas c
        INNER JOIN tb_Usuarios u ON c.IdPaciente = u.IdUsuario
        WHERE c.IdMedico = @IdUsuario
        ORDER BY c.FechaCita, c.HoraInicio;
    END
END
GO

--registro de uan cita
CREATE or alter  PROCEDURE usp_RegistrarCitaConPago
(
    @IdPaciente INT,
    @IdMedico INT,
    @Fecha DATE,
    @HoraInicio TIME,
    @HoraFin TIME,
    @Monto DECIMAL(10,2),
    @IdTransaccion VARCHAR(100) -- se recibe pero no se guarda (por ahora)
)
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    DECLARE @IdCita INT = 0;

    BEGIN TRY
        BEGIN TRAN;

        -- 1️ Validar que el horario no esté ocupado
        IF EXISTS (
            SELECT 1
            FROM tb_Citas
            WHERE IdMedico = @IdMedico
              AND CONVERT(DATE, FechaCita) = @Fecha
              AND HoraInicio = @HoraInicio
              AND HoraFin = @HoraFin
              AND Estado <> 'C'
        )
        BEGIN
            ROLLBACK;
            SELECT -1;
            RETURN;
        END

        -- 2️ Registrar la cita (P = Pagada/Pendiente según tu lógica)
        INSERT INTO tb_Citas
        (
            IdPaciente,
            IdMedico,
            FechaCita,
            HoraInicio,
            HoraFin,
            MontoPagar,
            Estado
        )
        VALUES
        (
            @IdPaciente,
            @IdMedico,
            CAST(@Fecha AS DATETIME),
            @HoraInicio,
            @HoraFin,
            @Monto,
            'P'
        );

        SET @IdCita = SCOPE_IDENTITY();

        COMMIT;

        -- 3️ Devolver IdCita (esto espera tu C#)
        SELECT @IdCita;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0
            ROLLBACK;

        THROW;
    END CATCH
END;
GO

	
CREATE OR ALTER PROCEDURE sp_AtenderCita
(
    @IdCita INT,
    @Estado CHAR(1),            -- 'A'=Atendida, 'C'=Cancelada, etc.
    @Nota NVARCHAR(500) = NULL
)
AS
BEGIN
    SET NOCOUNT ON;

    BEGIN TRY
        BEGIN TRAN;

        IF NOT EXISTS (SELECT 1 FROM tb_Citas WHERE IdCita = @IdCita)
        BEGIN
            RAISERROR('Cita no encontrada', 16, 1);
            ROLLBACK;
            RETURN;
        END

        UPDATE tb_Citas
        SET Estado = @Estado
        WHERE IdCita = @IdCita;

        IF(@Nota IS NOT NULL AND @Nota <> '')
        BEGIN
            INSERT INTO tb_CitaNotas (IdCita, Nota)
            VALUES (@IdCita, @Nota);
        END

        COMMIT;
    END TRY
    BEGIN CATCH
        ROLLBACK;
        RAISERROR('Error al atender la cita',16,1);
    END CATCH
END
GO


CREATE OR ALTER PROCEDURE sp_ListarHorariosDisponibles
(
    @IdMedico INT,
    @Fecha DATE
)
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @Hoy DATE = CAST(GETDATE() AS DATE);
    DECLARE @HoraActual TIME = CAST(GETDATE() AS TIME);

    SELECT 
        h.IdHorario,
        h.HoraInicio,
        h.HoraFin
    FROM tb_HorariosMedico h
    WHERE h.IdMedico = @IdMedico
      AND h.Fecha = @Fecha
      AND h.Disponible = 1

      --  no mostrar horarios ya reservados
      AND NOT EXISTS (
            SELECT 1
            FROM tb_Citas c
            WHERE c.IdMedico = h.IdMedico
              AND c.FechaCita = h.Fecha
              AND c.HoraInicio = h.HoraInicio
              AND c.Estado <> 'C'
      )

      --  lógica correcta de tiempo
      AND (
            -- FUTURO → mostrar todo
            @Fecha > @Hoy

            -- HOY → solo horas futuras
            OR (
                @Fecha = @Hoy
                AND h.HoraInicio > @HoraActual
            )
      )
    ORDER BY h.HoraInicio;
END
GO

